# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Next.js build output
.next/
out/

# Build and production outputs
build/
dist/
.turbo/

# Debug and log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local environment files (ignore all except .env.example files)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local

# Allow committing .env.example files
!.env.example
!*.env.example

# Editor and OS files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvsca
*.njsproj
*.sln
*.sw?
.eslintcache

# Miscellaneous
*.pem
*.key
.vercel
*.tsbuildinfo
